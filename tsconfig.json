{
  "compilerOptions": {
    "target": "es6",
    "lib": ["dom", "esnext", "esnext.intl", "es2017.intl", "es2018.intl"],
    "paths": {
      "*": ["./src/*"]
    },
    "types": ["node", "jest"],
    "rootDir": ".",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": false,
    "outDir": "build",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx"
  },
  "include": ["src"]
}
